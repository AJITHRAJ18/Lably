{
  "name": "lably",
  "version": "1.0.0",
  "description": "Lably — Enterprise Lab Results Translator. AI-powered medical lab report simplification.",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" --names \"API,UI\" --prefix-colors \"blue,green\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\" --names \"API,UI\" --prefix-colors \"blue,green\"",
    "start:server": "cd server && npm start",
    "start:client": "cd client && npm run preview",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "lint": "cd client && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
