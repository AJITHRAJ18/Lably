# ============================================================
# Lably — Root Environment Variables
# Copy this file to .env in both server/ and client/
# ============================================================

# ── Server (server/.env) ─────────────────────────────────────

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # Service role key (server only — never expose client-side)

# Razorpay
RAZORPAY_KEY_ID=rzp_test_...         # Test: rzp_test_... | Live: rzp_live_...
RAZORPAY_KEY_SECRET=...               # From Razorpay dashboard → API Keys
RAZORPAY_WEBHOOK_SECRET=...           # From Razorpay dashboard → Webhooks
RAZORPAY_PLAN_MONTHLY=plan_...        # Monthly subscription plan ID

# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173         # Your frontend URL (used for redirects)
CLIENT_URL=http://localhost:5173      # CORS whitelist
ADMIN_EMAILS=admin@yourdomain.com     # Comma-separated admin emails

# ── Client (client/.env) ─────────────────────────────────────

# Supabase (public keys only — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...    # Anon/public key

# API URL (backend)
VITE_API_URL=http://localhost:3001
